local savedLightingProps = {}

local DISABLE_LIGHTING_CLASSES = {
    BloomEffect           = true,
    DepthOfFieldEffect    = true,
    BlurEffect            = true,
    ColorGradingEffect    = true,
    ColorCorrectionEffect = true,
    Atmosphere            = true,
}

local function disableLightingEffects()
    for _, obj in ipairs(Lighting:GetDescendants()) do
        if DISABLE_LIGHTING_CLASSES[obj.ClassName] and savedLightingProps[obj] == nil then
            local ok, enabled = pcall(function() return obj.Enabled end)
            if ok then
                savedLightingProps[obj] = enabled
                pcall(function() obj.Enabled = false end)
            end
        end
    end
end

local function enableLightingEffects()
    for obj, wasEnabled in pairs(savedLightingProps) do
        if typeof(obj) == "Instance" and obj.Parent then
            pcall(function() obj.Enabled = wasEnabled end)
        end
    end
    savedLightingProps = {}
end

