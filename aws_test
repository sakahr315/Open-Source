local sessionStart = os.time()

local function getElapsedHours()
    local secs = os.time() - sessionStart
    return math.max(secs / 3600, 1 / 3600)
end

local function getRate(value)
    local hrs = getElapsedHours()
    local rate = math.floor(value / hrs)
    if rate >= 1000 then
        return string.format("%.1fk/hr", rate / 1000)
    end
    return rate .. "/hr"
end

local function formatElapsed()
    local secs = os.time() - sessionStart
    local h = math.floor(secs / 3600)
    local m = math.floor((secs % 3600) / 60)
    local s = secs % 60
    if h > 0 then
        return string.format("%dh %02dm %02ds", h, m, s)
    end
    return string.format("%dm %02ds", m, s)
end

