    -- MRC logo (static PNG, small, centred — minimal texture overhead)
    local logo = Instance.new("ImageLabel")
    logo.Size                   = UDim2.new(0, 110, 0, 110)
    logo.Position               = UDim2.new(0.5, -55, 0.5, -75)
    logo.BackgroundTransparency = 1
    logo.Image                  = MRC_LOGO_ASSET_ID
    logo.ScaleType              = Enum.ScaleType.Fit
    logo.Parent                 = blackOverlayGui

    -- Status label below logo
    local lbl = Instance.new("TextLabel")
    lbl.Size                   = UDim2.new(1, 0, 0, 24)
    lbl.Position               = UDim2.new(0, 0, 0.5, 45)
    lbl.BackgroundTransparency = 1
    lbl.Text                   = "⚡ Screen Hidden — toggle off to restore"
    lbl.TextColor3             = Color3.fromRGB(110, 70, 210)
    lbl.Font                   = Enum.Font.GothamBold
    lbl.TextSize               = 12
    lbl.Parent                 = blackOverlayGui

    -- 2. DISABLE ALL SCREENGUIS (except MRC's own)
    savedGuiStates = {}
    for _, gui in ipairs(pg:GetChildren()) do
        if gui:IsA("ScreenGui") and not PROTECTED_GUIS[gui.Name] then
            savedGuiStates[gui] = gui.Enabled
            gui.Enabled = false
        end
    end

    -- 3. DISABLE NPC ANIMATE / IDLE / WAVE SCRIPTS in workspace
    savedScriptStates = {}
    local char = LocalPlayer.Character
    task.spawn(function()
        for _, obj in ipairs(workspace:GetDescendants()) do
            if (obj:IsA("LocalScript") or obj:IsA("Script"))
                and (obj.Name == "Animate" or obj.Name == "IdleScript" or obj.Name == "WaveScript")
                and not (char and obj:IsDescendantOf(char))
            then
                savedScriptStates[obj] = obj.Enabled
                pcall(function() obj.Enabled = false end)
            end
        end
    end)

    -- 4. DISABLE PARTICLES, BEAMS, TRAILS in workspace
    savedParticleStates = {}
    task.spawn(function()
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("ParticleEmitter") or obj:IsA("Beam") or obj:IsA("Trail") then
                savedParticleStates[obj] = obj.Enabled
                pcall(function() obj.Enabled = false end)
            end
        end
    end)

    -- 5. MUTE ALL SOUNDS in workspace
    savedSoundStates = {}
    task.spawn(function()
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("Sound") then
                savedSoundStates[obj] = obj.Volume
                pcall(function() obj.Volume = 0 end)
            end
        end
    end)

    -- 6. CAMERA TO VOID (stops world render entirely)
    local cam = workspace.CurrentCamera
    savedCamType   = cam.CameraType
    savedCamCFrame = cam.CFrame
    cam.CameraType = Enum.CameraType.Scriptable
    cam.CFrame     = CFrame.new(0, -100000, 0)

    -- 7. ALL LIGHTING FX (full pass, catches nested folders)
    task.spawn(function()
        for _, obj in ipairs(Lighting:GetDescendants()) do
            local cn = obj.ClassName
            if cn == "BloomEffect" or cn == "DepthOfFieldEffect"
                or cn == "BlurEffect" or cn == "ColorCorrectionEffect"
                or cn == "ColorGradingEffect" or cn == "Atmosphere"
            then
                if savedLightingProps[obj] == nil then
                    local ok, en = pcall(function() return obj.Enabled end)
                    if ok then
                        savedLightingProps[obj] = en
                        pcall(function() obj.Enabled = false end)
                    end
                end
            end
        end
    end)
end

local function showScreen()
    -- Remove overlay
    if blackOverlayGui then
        blackOverlayGui:Destroy()
        blackOverlayGui = nil
    end

    -- Restore ScreenGuis
    for gui, wasEnabled in pairs(savedGuiStates) do
        if gui and gui.Parent then
            pcall(function() gui.Enabled = wasEnabled end)
        end
    end
    savedGuiStates = {}

    -- Restore NPC scripts
    for scr, wasEnabled in pairs(savedScriptStates) do
        if scr and scr.Parent then
            pcall(function() scr.Enabled = wasEnabled end)
        end
    end
    savedScriptStates = {}

    -- Restore particles/beams/trails
    for obj, wasEnabled in pairs(savedParticleStates) do
        if obj and obj.Parent then
            pcall(function() obj.Enabled = wasEnabled end)
        end
    end
    savedParticleStates = {}

    -- Restore sounds
    for obj, vol in pairs(savedSoundStates) do
        if obj and obj.Parent then
            pcall(function() obj.Volume = vol end)
        end
    end
    savedSoundStates = {}

    -- Restore camera
    local cam = workspace.CurrentCamera
    if savedCamType then
        cam.CameraType = savedCamType
        savedCamType   = nil
    end
    if savedCamCFrame then
        cam.CFrame     = savedCamCFrame
        savedCamCFrame = nil
    end

    -- Restore lighting (reuses existing table + function)
    enableLightingEffects()
end

