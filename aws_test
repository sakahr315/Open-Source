local function checkMilestone(key, value)
    local list = Milestones[key]
    if not list then return end
    for _, threshold in ipairs(list) do
        if value >= threshold and not MilestonesHit[key][threshold] then
            MilestonesHit[key][threshold] = true
            Rayfield:Notify({
                Title    = milestoneIcons[key] .. " Milestone Hit!",
                Content  = threshold .. " " .. key .. " reached! Share the hub: discord.gg/YV3GjGw3PY",
                Duration = 6,
                Image    = 4483362458,
            })
        end
    end
end

