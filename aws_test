local function mutateBatch()
    if not PetRF or not MutateRF then return end
    local success, pets = pcall(function() return PetRF:InvokeServer(LocalPlayer) end)
    if not success or typeof(pets) ~= "table" then return end
    for uuid, data in pairs(pets) do
        if not State.mutating then break end
        if data and not data.Locked and not data.Cure then
            pcall(function() MutateRF:InvokeServer(uuid, {}) end)
            Stats.mutations += 1
            updateStatLabel("mutations")
            checkMilestone("mutations", Stats.mutations)
            task.wait(math.random(40, 70) / 100)
        end
    end
end

local function startAutoMutate()
    while State.mutating do mutateBatch(); task.wait(2) end
end

