local carrotFolder = workspace:WaitForChild("GameObjects"):WaitForChild("Carrots")

local function collectCarrot(carrot)
    if not RF then return end
    local zone = carrot:GetAttribute("CarrotZone")
    local guid = carrot:GetAttribute("CarrotGuid")
    if zone and guid then
        pcall(function() RF:InvokeServer(zone, guid) end)
        Stats.carrots += 1
        updateStatLabel("carrots")
        checkMilestone("carrots", Stats.carrots)
        carrot:Destroy()
    end
end

local function startCollecting()
    for _, carrot in ipairs(carrotFolder:GetChildren()) do
        collectCarrot(carrot)
    end
    connection = carrotFolder.ChildAdded:Connect(function(carrot)
        task.wait(0.05)
        collectCarrot(carrot)
    end)
end

local function stopCollecting()
    if connection then
        connection:Disconnect()
        connection = nil
    end
end

-- ================================================
-- DYNAMIC HATCH COUNT
-- ================================================
local function getHatchCount()
    local ok, result = pcall(function()
        local customHatch = LocalPlayer.PlayerGui.GameUI.Menus.EggOpen.CustomHatch
        for _, v in ipairs(customHatch:GetChildren()) do
            if v:IsA("TextLabel") and string.find(v.Text, "Max") then
                local num = string.match(v.Text, "%d+")
                if num then return tonumber(num) end
            end
        end
    end)
    return (ok and type(result) == "number" and result > 1) and result or 1
end

-- ================================================
-- AUTO HATCH (NORMAL)
-- ================================================
local function startHatching()
    while State.hatching do
        if EggRF then
            local count  = getHatchCount()
            local isBulk = count > 1
            local ok, result = pcall(function()
                if isBulk then
                    return EggRF:InvokeServer("Bunny", nil, nil, true, true, true, nil)
                else
                    return EggRF:InvokeServer("Bunny", nil, nil, false, nil, nil, nil)
                end
            end)
            if ok and result then
                Stats.eggs += count
                updateStatLabel("eggs")
                checkMilestone("eggs", Stats.eggs)
            end
        end
        task.wait(0.15 + math.random(0, 5) / 100)
    end
end

