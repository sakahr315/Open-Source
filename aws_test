PremiumTab:CreateSection("Premium Access")

PremiumTab:CreateInput({
    Name                     = "Enter Premium Key",
    PlaceholderText          = "MRC-PREM-XXXX",
    RemoveTextAfterFocusLost = false,
    Flag                     = "PremiumKeyInput",
    Callback                 = function(inputVal)
        local valid = false
        for _, key in ipairs(PREMIUM_KEYS) do
            if inputVal == key then valid = true; break end
        end

        if valid then
            premiumUnlocked = true
            Rayfield:Notify({
                Title    = "⭐ Premium Unlocked!",
                Content  = "Welcome! All premium features are now available.",
                Duration = 6,
                Image    = 4483362458,
            })

            -- Dynamically create premium features after key accepted
            PremiumTab:CreateSection("Auto Index")

            PremiumTab:CreateDropdown({
                Name          = "Index Hatch Type",
                Options       = {"Single (1x)", "Triple (3x)", "Octuple (8x)"},
                CurrentOption = {"Single (1x)"},
                Flag          = "PremIndexHatchType",
                Callback      = function(v)
                    indexHatchType = v[1]
                end,
            })

            PremiumTab:CreateToggle({
                Name         = "Auto Index (All Eggs, Worst → Best)",
                CurrentValue = false,
                Flag         = "PremAutoIndex",
                Callback     = function(v)
                    if v and not checkRemotes("Auto Index") then return end
                    autoIndexing = v
                    if v then
                        cancelStatsRemoval()
                        createStatsUI()
                        safeNotify({
                            Title    = "Auto Index Started",
                            Content  = "Cycling all eggs worst → best, 30–60s each.",
                            Duration = 5,
                            Image    = 4483362458,
                        })
                        task.spawn(function()
                            local fullList = {}
                            for _, world in ipairs(worldOrder) do
                                for _, egg in ipairs(EggData[world]) do
                                    table.insert(fullList, { world = world, egg = egg })
                                end
                            end

                            local totalEggs = #fullList

                            for idx, entry in ipairs(fullList) do
                                if not autoIndexing then break end

                                local eggName   = entry.egg
                                local worldName = entry.world
                                local duration  = math.random(30, 60)
                                local elapsed   = 0
                                local interval  = 0.15 + math.random(0, 8) / 100

                                safeNotify({
                                    Title    = "Index — Egg " .. idx .. "/" .. totalEggs,
                                    Content  = worldName .. " — " .. eggName .. " (" .. duration .. "s)",
                                    Duration = 5,
                                    Image    = 4483362458,
                                })

                                while autoIndexing and elapsed < duration do
                                    if EggRF then
                                        local count = 1
                                        local ok, result = pcall(function()
                                            if indexHatchType == "Single (1x)" then
                                                count = 1
                                                return EggRF:InvokeServer(eggName, {}, false)
                                            elseif indexHatchType == "Triple (3x)" then
                                                count = 3
                                                return EggRF:InvokeServer(eggName, {}, true, false)
                                            else
                                                count = 8
                                                return EggRF:InvokeServer(eggName, {}, false, true)
                                            end
                                        end)
                                        if ok and result then
                                            Stats.eggs += count
                                            updateStatLabel("eggs")
                                            checkMilestone("eggs", Stats.eggs)
                                        end
                                    end
                                    task.wait(interval)
                                    elapsed += interval
                                end
                            end

                            if autoIndexing then
                                autoIndexing = false
                                Rayfield:Notify({
                                    Title    = "Auto Index Complete",
                                    Content  = "All eggs cycled! Toggle is now off.",
                                    Duration = 6,
                                    Image    = 4483362458,
                                })
                            end
                            scheduleStatsRemoval()
                        end)
                    else
                        scheduleStatsRemoval()
                    end
                end,
            })

        else
            premiumUnlocked = false
            Rayfield:Notify({
                Title    = "❌ Invalid Key",
                Content  = "That key is incorrect. Join discord.gg/YV3GjGw3PY for a key.",
                Duration = 6,
                Image    = 4483362458,
            })
        end
    end,
})

