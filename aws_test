local RARE_PETS = {
    "Giga Egg Fox",
    "Mega Easter Goat",
    "Olympic Blade Carrot",
}

local rareCooldowns = {}
local RARE_COOLDOWN = 30

local function stripRichText(str)
    return str:gsub("<[^>]+>", "")
end

local function setupChatRareDetection()
    local ok = pcall(function()
        TextChatService.MessageReceived:Connect(function(msg)
            local raw = msg.Text or ""
            local plain = stripRichText(raw)
            for _, petName in ipairs(RARE_PETS) do
                if string.find(plain, petName, 1, true) then
                    local now = os.clock()
                    if not rareCooldowns[petName] or (now - rareCooldowns[petName]) > RARE_COOLDOWN then
                        rareCooldowns[petName] = now
                        sendRareWebhook(petName, plain:sub(1, 120))
                    end
                    break
                end
            end
        end)
    end)
    if not ok then
        warn("[MRC Hub] TCS.MessageReceived hook failed — rare detection unavailable")
    end
end
task.spawn(setupChatRareDetection)

