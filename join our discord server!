--// Load Kavo UI Library
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()

--// Simple Loading Screen (no steps)
local function LoadingIntro()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "LoadingScreen"
    screenGui.Parent = game:GetService("CoreGui")

    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1,0,1,0)
    text.BackgroundTransparency = 1
    text.TextColor3 = Color3.fromRGB(255,255,255)
    text.Font = Enum.Font.GothamBold
    text.TextScaled = true
    text.Text = "MRC Scripts\nLoading..."
    text.Parent = screenGui

    task.wait(2)

    screenGui:Destroy()
end

LoadingIntro()

--// Create Window
local Window = Library.CreateLib("Access Required - MRC Scripts", "DarkTheme")

--// Tab
local Tab = Window:NewTab("Access")
local Section = Tab:NewSection("Discord Required")

--// Labels
Section:NewLabel("This script is locked behind Discord access")
Section:NewLabel("Join our server for keyless access")

--// Discord Button
Section:NewButton("Join Discord Server", "Opens Discord & copies invite", function()
    local invite = "https://discord.com/invite/YV3GjGw3PY"

    -- copy invite
    setclipboard(invite)

    -- notification
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Discord Invite Ready",
        Text = "Link copied + opening Discord",
        Duration = 5
    })

    -- open link
    pcall(function()
        syn.request({
            Url = invite,
            Method = "GET"
        })
    end)

    -- fallback
    pcall(function()
        game:GetService("GuiService"):OpenBrowserWindow(invite)
    end)
end)
