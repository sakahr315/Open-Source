-- ── Teleport Helper ─────────────────────────────────────────────────
local function teleportToEnchant()
    local char = lp.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end

    local pad = workspace:FindFirstChild("__MAP")
        and workspace.__MAP:FindFirstChild("Interactive")
        and workspace.__MAP.Interactive:FindFirstChild("Enchanting")
        and workspace.__MAP.Interactive.Enchanting:FindFirstChild("Pad")

    if pad then
        char.HumanoidRootPart.CFrame = pad.CFrame + Vector3.new(0, 3, 0)
    end
end

-- ── Farm Helpers ─────────────────────────────────────────────────────
local function getMyPetUIDs()
    local uids = {}
    local petsFolder = workspace:FindFirstChild("__THINGS") and workspace.__THINGS:FindFirstChild("Pets")
    if not petsFolder then return uids end
    local char = lp.Character
    if not char or not char.PrimaryPart then return uids end

    for _, part in ipairs(petsFolder:GetChildren()) do
        if part.Name:sub(1,2) == "id" and #part.Name > 10 then
            if (part.CFrame.Position - char.PrimaryPart.CFrame.Position).Magnitude < 60 then
                table.insert(uids, part.Name)
                if #uids >= Config.MaxPets then break end
            end
        end
    end
    return uids
end

local function getActiveCoins()
    local coins = {}
    local char = lp.Character
    local coinsFolder = workspace:FindFirstChild("__THINGS") and workspace.__THINGS:FindFirstChild("Coins")
    if not coinsFolder then return coins end

    for _, zone in ipairs(coinsFolder:GetChildren()) do
        local health = zone:GetAttribute("Health")
        local landed = zone:GetAttribute("HasLanded")
        local id     = zone:GetAttribute("ID")

        if id and health and health > 0 and landed == true then
            local coinPart = zone:FindFirstChild("POS") or zone:FindFirstChild("Coin")
            if coinPart and char and char.PrimaryPart then
                local dist = (coinPart.CFrame.Position - char.PrimaryPart.CFrame.Position).Magnitude
                if dist <= Config.FarmRange then
                    table.insert(coins, { id = id, name = zone.Name })
                end
            end
        end
    end
    return coins
end

-- ── Enchant Helpers ──────────────────────────────────────────────────
local function getEquippedPetUIDs()
    if not Library then return {} end
    local save = Library.Save.Get()
    if not save then return {} end

    local uids = {}
    for _, pet in ipairs(save.Pets or {}) do
        if Library.Shared.HasPetEquipped(save, pet) then
            table.insert(uids, pet.uid)
        end
    end
    return uids
end

local function petHasDesiredEnchant(petData)
    if not petData or not petData.powers then return false end
    for _, power in ipairs(petData.powers) do
        local powerDir = Library.Directory.Powers[power[1]]
        if powerDir then
            local tier = powerDir.tiers[power[2]]
            if tier and EnchantConfig.SelectedPowers[tier.title] then
                return true
            end
        end
    end
    return false
end

local function getAllEnchantTitles()
    if not Library then return {} end
    local titles = {}

    for _, power in pairs(Library.Directory.Powers) do
        if power.canDrop then
            for _, tier in ipairs(power.tiers) do
                table.insert(titles, tier.title)
            end
        end
    end

    table.sort(titles)
    return titles
end

-- ── Farm Loop ────────────────────────────────────────────────────────
task.spawn(function()
    while true do
        if Config.AutoFarm then
            local petUIDs = getMyPetUIDs()
            if #petUIDs > 0 then
                local coins = getActiveCoins()
                for _, coin in ipairs(coins) do
                    pcall(function()
                        JoinCoinRemote:InvokeServer(coin.id, petUIDs)
                    end)
                    for _, uid in ipairs(petUIDs) do
                        pcall(function()
                            FarmCoinRemote:FireServer(coin.id, uid)
                        end)
                    end
                end
            end
        end
        task.wait(0)
    end
end)

-- ── Enchant Loop ─────────────────────────────────────────────────────
task.spawn(function()
    while true do
        if EnchantConfig.AutoEnchant and Library then
            local uids = getEquippedPetUIDs()
            local toEnchant = {}

            for _, uid in ipairs(uids) do
                local petData = Library.PetCmds.Get(uid)
                if petData and not petHasDesiredEnchant(petData) then
                    table.insert(toEnchant, uid)
                    if #toEnchant >= 3 then break end
                end
            end

            if #toEnchant > 0 then
                local autoMode = next(EnchantConfig.SelectedPowers) ~= nil
                pcall(function()
                    Library.Network.Invoke("Enchant Pets", toEnchant, autoMode)
                end)
            else
                EnchantConfig.AutoEnchant = false
                Rayfield:Notify({
                    Title = "Auto Enchant",
                    Content = "Done!",
                    Duration = 3,
                })
            end
        end
        task.wait(EnchantConfig.DelayBetween)
    end
end)

-- ── Hatch Loop ───────────────────────────────────────────────────────
task.spawn(function()
    while true do
        if HatchConfig.AutoHatch then
            pcall(function()
                HatchRemote:InvokeServer(
                    HatchConfig.SelectedEgg,
                    true,
                    false
                )
            end)
        end
        task.wait(0.2)
    end
end)

